<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- App Icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋"
            android:textSize="48sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="澎湃OS剪贴板补全"
            android:textColor="#FFFFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Version -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0"
            android:textColor="#88FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginBottom="24dp" />

        <!-- Description Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="模块说明"
                android:textColor="#FF88CCFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="修复 HyperOS 3.0 第三方输入法无法使用系统剪贴板的问题"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- Developer Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开发者"
                android:textColor="#FF88CCFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- 酷安 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="酷安："
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvCoolapk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="江上晚"
                    android:textColor="#FF66AAFF"
                    android:textSize="14sp"
                    android:background="?android:attr/selectableItemBackground" />
            </LinearLayout>

            <!-- 微博 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="微博："
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvWeibo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="李十六的日记本"
                    android:textColor="#FF66AAFF"
                    android:textSize="14sp"
                    android:background="?android:attr/selectableItemBackground" />
            </LinearLayout>
        </LinearLayout>

        <!-- About Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="关于"
                android:textColor="#FF88CCFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="各位大佬，这是我第一次自己写模块，模块有问题可以通过酷安或者微博私信告诉我，能不能改成功我就不知道了，因为这个模块能写成功有一半都是AI的功劳。"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GitHub："
                    android:textColor="#88FFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvGithub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="jiangshangwan/ClipboardFix"
                    android:textColor="#FF66AAFF"
                    android:textSize="13sp"
                    android:background="?android:attr/selectableItemBackground" />
            </LinearLayout>
        </LinearLayout>

        <!-- Donate Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="20dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☕ 打赏支持"
                android:textColor="#FF88CCFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="您的支持就是我的最大动力"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <ImageView
                android:id="@+id/imgDonate"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/donate_qrcode"
                android:scaleType="fitCenter"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="点击图片 → 保存并打开微信「扫一扫→相册」"
                android:textColor="#88FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Hide / Show Desktop Icon Button -->
        <Button
            android:id="@+id/btnHideIcon"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="隐藏桌面图标"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:background="@drawable/btn_hide_bg"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="by 江上晚"
            android:textColor="#44FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
