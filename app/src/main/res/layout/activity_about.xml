<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- App Icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋"
            android:textSize="48sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="澎湃OS剪贴板补全"
            android:textColor="#FFFFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Version -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0"
            android:textColor="#88FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <!-- Hint -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="隐藏桌面图标请下滑到最下方点击隐藏桌面图标"
            android:textColor="#66FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginBottom="24dp" />

        <!-- Description Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="模块说明"
                android:textColor="#FF88CCFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="修复HyperOS 3.0常用语和剪贴板V4.7.7在第三方输入法下无法读取系统剪贴板历史记录问题。&#10;&#10;目前本人就只测试了微信输入法，其他输入法暂时没有测试，是否生效请执行测试，如有问题请通过微博、酷安私信反馈。&#10;&#10;安装后请在LSPosed内勾选剪贴板和常用语作用域，完成后请重启手机！！！重启手机！！！重启手机！！！"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- Developer Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="开发者"
                android:textColor="#FF88CCFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <!-- 酷安 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="酷安："
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvCoolapk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="江上晚"
                    android:textColor="#FF66AAFF"
                    android:textSize="14sp"
                    android:background="?android:attr/selectableItemBackground" />
            </LinearLayout>

            <!-- 微博 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="微博："
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvWeibo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="李十六的日记本"
                    android:textColor="#FF66AAFF"
                    android:textSize="14sp"
                    android:background="?android:attr/selectableItemBackground" />
            </LinearLayout>

            <!-- GitHub -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GitHub："
                    android:textColor="#CCFFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvGithub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="jiangshangwan/ClipboardFix"
                    android:textColor="#FF66AAFF"
                    android:textSize="14sp"
                    android:background="?android:attr/selectableItemBackground" />
            </LinearLayout>
        </LinearLayout>

        <!-- About Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="关于"
                android:textColor="#FF88CCFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="这是本人第一是写LSPosed模块，不足之处还请见谅，模块本身就几百KB，应该没有什么BUG，如您有更好的建议或者发现对其他第三方输入法不生效请通过&#10;微博、酷安进行反馈，反馈时请提供您使用的输入法包名，反馈后可能没办法及时修复。"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- Donate Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="20dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☕ 打赏支持"
                android:textColor="#FF88CCFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="您的支持就是我的最大动力"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <ImageView
                android:id="@+id/imgDonate"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/donate_qrcode"
                android:scaleType="fitCenter"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="点击图片 → 保存并打开微信「扫一扫→相册」"
                android:textColor="#88FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Hide / Show Desktop Icon Button -->
        <Button
            android:id="@+id/btnHideIcon"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="隐藏桌面图标"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:background="@drawable/btn_hide_bg"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="12dp" />

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="by 江上晚"
            android:textColor="#44FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />
        

    </LinearLayout>
</ScrollView>
