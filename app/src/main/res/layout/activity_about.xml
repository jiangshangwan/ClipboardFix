<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- App Icon -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋"
            android:textSize="48sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="澎湃OS剪贴板补全"
            android:textColor="#FFFFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <!-- Version -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.2"
            android:textColor="#88FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- Card: 模块说明 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="模块说明"
                android:textColor="#FF88CCFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="修复HyperOS 3.0常用语和剪贴板v4.7.7&#10;第三方输入法无法读取系统剪贴板历史记录的问题。&#10;&#10;目前本人就只测试了微信输入法，其他输入法暂时没有测试。"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="支持的输入法"
                android:textColor="#FF88CCFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="• 微信输入法（com.tencent.wetype）&#10;• 搜狗输入法小米版（com.sohu.inputmethod.sogou.xiaomi）&#10;• 其他第三方输入法（理论上均可）"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="安装后请在LSPosed内勾选作用域「剪贴板和常用语」，完成设置后请重启手机！"
                android:textColor="#FFCC66"
                android:textSize="13sp"
                android:layout_marginTop="12dp"
                android:lineSpacingMultiplier="1.4" />
        </LinearLayout>

        <!-- Card: 意见反馈 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="意见反馈"
                android:textColor="#FF88CCFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="如您有更好的建议或发现对其他输入法不生效，&#10;请通过微博、酷安反馈，反馈时请提供您使用的输入法包名。"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5" />

            <!-- 酷安 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="酷安："
                    android:textColor="#88FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvCoolapk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="江上晚"
                    android:textColor="#FF66AAFF"
                    android:textSize="14sp"
                    android:background="?android:attr/selectableItemBackground" />
            </LinearLayout>

            <!-- 微博 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="微博："
                    android:textColor="#88FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvWeibo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="李十六的日记本"
                    android:textColor="#FF66AAFF"
                    android:textSize="14sp"
                    android:background="?android:attr/selectableItemBackground" />
            </LinearLayout>

            <!-- GitHub -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="GitHub："
                    android:textColor="#88FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvGithub"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="jiangshangwan/ClipboardFix"
                    android:textColor="#FF66AAFF"
                    android:textSize="14sp"
                    android:background="?android:attr/selectableItemBackground" />
            </LinearLayout>
        </LinearLayout>

        <!-- Card: 打赏支持 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_bg"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☕ 打赏支持"
                android:textColor="#FF88CCFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="您的支持就是我的最大动力"
                android:textColor="#CCFFFFFF"
                android:textSize="14sp"
                android:layout_marginBottom="16dp" />

            <ImageView
                android:id="@+id/imgDonate"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:src="@drawable/donate_qrcode"
                android:scaleType="fitCenter"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="点击图片 → 保存并打开微信「扫一扫→相册」"
                android:textColor="#88FFFFFF"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Check Update Button -->
        <Button
            android:id="@+id/btnCheckUpdate"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="🔍 检查更新"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:background="@drawable/btn_show_bg"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp" />

        <!-- Hide / Show Desktop Icon Button -->
        <Button
            android:id="@+id/btnHideIcon"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="隐藏桌面图标"
            android:textColor="#FFFFFFFF"
            android:textSize="15sp"
            android:background="@drawable/btn_hide_bg"
            android:layout_marginBottom="16dp" />

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="by 江上晚"
            android:textColor="#44FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="16dp" />

    </LinearLayout>
</ScrollView>
